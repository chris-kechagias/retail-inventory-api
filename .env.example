# --- DATABASE CONFIGURATION ---

# OPTION 1: LOCAL (Docker Compose)
# Usage: Rapid development and when out of internet connection.
# DB_USERNAME=your_local_username
# DB_PASSWORD=your_local_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=retail_inventory_db

# OPTION 2: SUPABASE (Cloud)
# Usage: Cloud PostgreSQL via Supabase transaction pooler (IPv4 compatible).
# Get connection details from: Supabase Dashboard -> Connect -> Transaction pooler -> View parameters
# DB_USERNAME=postgres.<your-project-ref>
# DB_PASSWORD=your_supabase_password
# DB_HOST=aws-1-<region>.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
